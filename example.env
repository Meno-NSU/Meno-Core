# LLM / OpenAI
OPENAI_API_KEY=YOUR_TOKEN
OPENAI_BASE_URL=http://127.0.0.1:9020/v1
# LLM_MODEL_NAME is optional when VLLM_ENDPOINTS is set:
# the backend will discover available models and use the first one automatically.
# If set, it must match a model ID returned by /v1/models on the vLLM endpoint.
# LLM_MODEL_NAME=

# Embeddings / reranker
MULTILINGUAL_EMBEDDER_PATH=Alibaba-NLP/gte-multilingual-base
RUS_EMBEDDER_PATH=deepvk/USER2-base
RERANKER_PATH=Qwen/Qwen3-Reranker-0.6B

# RAG
WORKING_DIR=light_rag_db_v2
ABBREVIATIONS_FILE=resources/full_abbreviations_updated.json
QUERY_MODE="mix"

# LINKS
ENABLE_LINKS_ADDITION=True
ENABLE_LINKS_CORRECTION=True
URLS_PATH="resources/validated_urls.json"
MAX_LINKS=3
TOP_K=30
DIST_THRESHOLD=0.70
CORRECT_DIST_THRESHOLD=0.1

# EMBEDDER
EMBEDDER_DIM=768
EMBEDDER_MAX_TOKENS=4096

# LIGHT RAG
TEMPERATURE=0.3
QUERY_MAX_TOKENS=4000

# LOGS
# All backend logs are emitted to stdout/stderr and can be redirected by the process runner.

# vLLM endpoints (comma-separated base URLs).
# The backend queries /v1/models on each endpoint at startup and validates
# all model names against this list before making any LLM calls.
VLLM_ENDPOINTS=http://127.0.0.1:9020

# CHUNK RAG
CHUNK_RAG_CORPUS_PATH="resources/Meno-NSU-Data/chunk_rag_corpus_512.jsonl"
CHUNK_RAG_DATA_PATH="resources/chunk_rag_data"
CHUNK_RAG_AUTO_REBUILD=False
CHUNK_RAG_TOP_K_DENSE_MULTILINGUAL=10
CHUNK_RAG_TOP_K_DENSE_RUSSIAN=10
CHUNK_RAG_TOP_K_BM25=10
CHUNK_RAG_FUSION_WEIGHT_MULTILINGUAL=0.35
CHUNK_RAG_FUSION_WEIGHT_RUSSIAN=0.35
CHUNK_RAG_FUSION_WEIGHT_BM25=0.30
CHUNK_RAG_DEBUG_RETRIEVAL=False
CHUNK_RAG_RETRIEVAL_LOG_LEVEL=INFO
CHUNK_RAG_RETRIEVAL_PREVIEW_K=5
